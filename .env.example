# ===== API keys (chi them tren Netlify, KHONG commit file .env) =====
# Gemini: bat buoc neu gui anh/PDF/Word
# https://aistudio.google.com/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Groq (tuy chon)
# https://console.groq.com/keys
GROQ_API_KEY="YOUR_GROQ_API_KEY"

# Cerebras (tuy chon)
# https://cloud.cerebras.ai/
CEREBRAS_API_KEY="YOUR_CEREBRAS_API_KEY"

# OpenRouter (tuy chon, mac dinh app dung openrouter/free)
# https://openrouter.ai/keys
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"

# URL site sau khi deploy Netlify (vi du: https://educhat-ai.netlify.app)
APP_URL="https://YOUR-SITE-NAME.netlify.app"
